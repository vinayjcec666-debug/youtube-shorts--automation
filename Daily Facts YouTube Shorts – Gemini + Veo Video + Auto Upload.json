      "parameters": {
        "jsCode": "// Extract the video URL from fal.ai completed response\nconst status = $input.first().json;\nconst fact = $('Extract Request ID').item.json;\n\nlet videoUrl = null;\n\nif (status.video?.url) {\n  videoUrl = status.video.url;\n} else if (status.output?.video?.url) {\n  videoUrl = status.output.video.url;\n} else if (status.result?.video?.url) {\n  videoUrl = status.result.video.url;\n}\n\nif (!videoUrl) {\n  throw new Error('Could not find video URL in response: ' + JSON.stringify(status));\n}\n\nreturn [{ json: { ...fact, video_url: videoUrl } }];"
      },
