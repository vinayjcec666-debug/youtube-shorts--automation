    },
    {
      "parameters": {
        "jsCode": "// fal.ai returns a request_id for async generation\n// Extract it and pass forward with all fact data\nconst response = $input.first().json;\nconst fact = $('Parse Script').item.json;\n\nconst requestId = response.request_id || response.id || null;\n\nif (!requestId) {\n  throw new Error('fal.ai did not return a request_id. Response: ' + JSON.stringify(response));\n}\n\nreturn [{ json: { ...fact, fal_request_id: requestId } }];"
      },
