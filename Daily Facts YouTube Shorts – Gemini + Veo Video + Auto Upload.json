    {
      "parameters": {
        "jsCode": "// Parse Gemini JSON output safely\nconst raw = $input.first().json.content;\nconst cleaned = raw.replace(/```json\\n?/g, '').replace(/```\\n?/g, '').trim();\n\nlet fact;\ntry {\n  fact = JSON.parse(cleaned);\n} catch(e) {\n  fact = {\n    title: 'Mind-Blowing Daily Fact #Shorts',\n    hook_word: 'Did you know',\n    fact_sentence: 'Honey never expires — archaeologists found 3000-year-old honey still edible in Egyptian tombs.',\n    bonus_sentence: 'It was perfectly preserved after 3000 years!',\n    cta: 'Follow for more!',\n    full_narration: 'Did you know honey never expires? Archaeologists found 3000-year-old honey in Egyptian tombs still perfectly edible! Follow for more!',\n    on_screen_text: 'HONEY NEVER EXPIRES!',\n    description: 'Did you know honey never expires? 3000-year-old honey found in Egyptian tombs was still edible! #Shorts #Facts #InterestingFacts #DidYouKnow #MindBlown',\n    tags: ['Shorts','Facts','InterestingFacts','DidYouKnow','MindBlown','DailyFacts','Education'],\n    topic_category: 'history',\n    veo_prompt: 'Cinematic 9:16 vertical video, photorealistic: Close-up of golden honey slowly pouring from an ancient clay pot inside a dimly lit Egyptian tomb. Warm amber light from a torch flickers across golden walls covered in hieroglyphics. The honey catches the light as it flows, revealing its perfect consistency. Camera slowly zooms out to reveal ancient jars and artifacts. Atmospheric fog adds mystery.',\n    estimated_seconds: 10\n  };\n}\n\nfact.generated_at = new Date().toISOString();\nfact.date_label = new Date().toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' });\nfact.day_number = Math.floor((new Date() - new Date('2025-01-01')) / 86400000) + 1;\nfact.word_count = (fact.full_narration || '').split(' ').length;\n\nreturn [{ json: fact }];"
      },
